{
  "concepts": {
    "http://example.org/oppchovec#WellBeing": {
      "label": "Well-being",
      "comment": "Central concept representing a general state of satisfaction, balance, and fulfillment experienced by individuals or collectives.",
      "uri": "http://example.org/oppchovec#WellBeing"
    },
    "http://example.org/oppchovec#QualityOfLife": {
      "label": "Quality of Life",
      "comment": "Concept encompassing the objective and subjective conditions that shape collective well-being.",
      "uri": "http://example.org/oppchovec#QualityOfLife"
    },
    "http://example.org/oppchovec#Happiness": {
      "label": "Happiness",
      "comment": "An individual affective or emotional state associated with pleasure and immediate satisfaction.",
      "uri": "http://example.org/oppchovec#Happiness"
    },
    "http://example.org/oppchovec#BuenVivir": {
      "label": "Buen Vivir",
      "comment": "A collective and territorial vision of living well, rooted in ecological balance and social relations.",
      "uri": "http://example.org/oppchovec#BuenVivir"
    },
    "http://example.org/oppchovec#EudaimonicWellBeing": {
      "label": "Eudaimonic well-being",
      "comment": "A dimension of well-being related to self-realization, purpose, and personal development.",
      "uri": "http://example.org/oppchovec#EudaimonicWellBeing"
    },
    "http://example.org/oppchovec#TerritorialWellBeing": {
      "label": "Territorial well-being",
      "comment": "A form of well-being associated with living conditions and the spatial, social, and environmental characteristics of a territory.",
      "uri": "http://example.org/oppchovec#TerritorialWellBeing"
    },
    "http://example.org/oppchovec#SubjectiveTerritorialWellBeing": {
      "label": "Subjective Territorial well-being",
      "comment": "A form of territorial well-being depending on how people feel about their situation.",
      "uri": "http://example.org/oppchovec#SubjectiveTerritorialWellBeing"
    },
    "http://example.org/oppchovec#ObjectiveTerritorialWellBeing": {
      "label": "Objective Territorial well-being",
      "comment": "A form of well-being depending on objective criteria on people's living conditions.",
      "uri": "http://example.org/oppchovec#ObjectiveTerritorialWellBeing"
    }
  },
